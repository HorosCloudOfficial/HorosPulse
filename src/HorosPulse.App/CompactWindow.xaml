<Window x:Class="HorosPulse.App.CompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:enums="clr-namespace:HorosPulse.Core.Enums;assembly=HorosPulse.Core"
        Title="HorosPulse Digi-Pet"
        Width="350"
        Height="640"
        MinWidth="330"
        MinHeight="540"
        SizeToContent="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        FontFamily="Segoe UI, Arial"
        Foreground="#F5F5F5"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <SolidColorBrush x:Key="SurviveBg" Color="#0A0A0A" />
        <SolidColorBrush x:Key="SurvivePanel" Color="#141414" />
        <SolidColorBrush x:Key="SurviveBorder" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurviveAccent" Color="#FF3864" />
        <SolidColorBrush x:Key="SurvivePink" Color="#FF6B9D" />
        <SolidColorBrush x:Key="SurviveWhite" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SurviveRed" Color="#CC1A2E" />
        <SolidColorBrush x:Key="SurviveMuted" Color="#888888" />
        <SolidColorBrush x:Key="SurviveHp" Color="#FF3864" />
        <SolidColorBrush x:Key="SurviveMp" Color="#FF6B9D" />
        <SolidColorBrush x:Key="SurviveSp" Color="#E8E8E8" />
        <SolidColorBrush x:Key="SurviveTired" Color="#8B7355" />

        <!-- Digi-hero palette (healthy / epic) -->
        <SolidColorBrush x:Key="DigiCyan" Color="#00E5FF" />
        <SolidColorBrush x:Key="DigiCyanSoft" Color="#4DF0FF" />
        <SolidColorBrush x:Key="DigiWhite" Color="#F0FAFF" />
        <SolidColorBrush x:Key="DigiPartnerOrange" Color="#FF9A3C" />
        <SolidColorBrush x:Key="DigiPartnerYellow" Color="#FFD54F" />
        <SolidColorBrush x:Key="DigiPartnerBlue" Color="#4FC3F7" />
        <SolidColorBrush x:Key="DigiGrid" Color="#2200E5FF" />

        <LinearGradientBrush x:Key="DigiShellBg" StartPoint="0,0" EndPoint="0.2,1">
            <GradientStop Color="#0B1624" Offset="0" />
            <GradientStop Color="#0E2238" Offset="0.55" />
            <GradientStop Color="#091420" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="DigiShellBorder" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#AA00E5FF" Offset="0" />
            <GradientStop Color="#66FFFFFF" Offset="0.5" />
            <GradientStop Color="#AA4DF0FF" Offset="1" />
        </LinearGradientBrush>

        <!-- Organic window silhouette -->
        <PathGeometry x:Key="OrganicShellClip">
            <PathFigure StartPoint="24,2" IsClosed="True">
                <BezierSegment Point1="120,0" Point2="200,1" Point3="302,2" />
                <BezierSegment Point1="316,6" Point2="318,20" Point3="318,38" />
                <LineSegment Point="318,618" />
                <BezierSegment Point1="318,624" Point2="310,628" Point3="298,628" />
                <LineSegment Point="48,628" />
                <BezierSegment Point1="16,628" Point2="2,614" Point3="2,586" />
                <LineSegment Point="2,38" />
                <BezierSegment Point1="2,14" Point2="10,2" Point3="24,2" />
            </PathFigure>
        </PathGeometry>

        <Storyboard x:Key="SbShardFloat" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-10" Duration="0:0:2.4" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.35" To="0.9" Duration="0:0:2.4" />
        </Storyboard>

        <Storyboard x:Key="SbGridPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.18" To="0.42" Duration="0:0:3.2" />
        </Storyboard>

        <Storyboard x:Key="SbWingGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.25" To="0.65" Duration="0:0:2" />
        </Storyboard>

        <Style x:Key="KillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="Prozess beenden (Not-Aus)" />
            <Setter Property="Background" Value="#33FF2244" />
            <Setter Property="Foreground" Value="#FFFF6688" />
            <Setter Property="BorderBrush" Value="#CCFF4466" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Panel.ZIndex" Value="200" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="KillRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="11">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF2244" BlurRadius="8" ShadowDepth="0" Opacity="0.55" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="KillRoot" Property="Background" Value="#66FF2244" />
                                <Setter TargetName="KillRoot" Property="BorderBrush" Value="#FFFF88AA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="KillRoot" Property="Background" Value="#AAFF0022" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Pet mood storyboards -->
        <Storyboard x:Key="SbIdlePulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             From="1" To="1.03" Duration="0:0:2.2" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             From="1" To="1.03" Duration="0:0:2.2" />
        </Storyboard>

        <Storyboard x:Key="SbHealthyBounce" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.35" Value="-8" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.7" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.4" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="SbTiredBreathe" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             From="1" To="0.9" Duration="0:0:2.6" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0.55" Duration="0:0:2.6" />
        </Storyboard>

        <Storyboard x:Key="SbSickShake" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.X)">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.05" Value="-5" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.1" Value="5" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="-4" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="4" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.25" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="SbSickPulse" RepeatBehavior="Forever" AutoReverse="True">
            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            To="#FF3864" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.35" To="1" Duration="0:0:0.5" />
        </Storyboard>

        <Storyboard x:Key="SbCrestIdlePulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.65" To="1" Duration="0:0:1.4" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             From="1" To="1.06" Duration="0:0:1.4" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             From="1" To="1.06" Duration="0:0:1.4" />
        </Storyboard>

        <Storyboard x:Key="SbSweatDrop" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="14" Duration="0:0:0.9" AutoReverse="True" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.85" To="0.15" Duration="0:0:0.9" AutoReverse="True" />
        </Storyboard>

        <Storyboard x:Key="SbHealFlash">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.65" To="0" Duration="0:0:0.6" />
        </Storyboard>

        <Storyboard x:Key="SbHealGlow" RepeatBehavior="3x" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                             To="1.3" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                             To="1.3" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0.95" Duration="0:0:0.25" />
            <ColorAnimation Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                            To="#FF6B9D" Duration="0:0:0.25" />
        </Storyboard>

        <Storyboard x:Key="SbHealPulse" RepeatBehavior="2x" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                             To="1.08" Duration="0:0:0.2" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                             To="1.08" Duration="0:0:0.2" />
        </Storyboard>

        <Storyboard x:Key="SbEatEnergy" RepeatBehavior="2x">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="20" To="-12" Duration="0:0:0.35" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.1" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"
                             BeginTime="0:0:0.15" />
        </Storyboard>

        <Storyboard x:Key="SbParticleBurst" RepeatBehavior="2x">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-32" Duration="0:0:0.7" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.05" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.65" BeginTime="0:0:0.05" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="16" Duration="0:0:0.7" />
        </Storyboard>

        <Storyboard x:Key="SbParticleBurst2" RepeatBehavior="2x">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-30" Duration="0:0:0.7" BeginTime="0:0:0.1" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.7" BeginTime="0:0:0.1" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="-15" Duration="0:0:0.7" BeginTime="0:0:0.1" />
        </Storyboard>

        <Storyboard x:Key="SbParticleBurst3" RepeatBehavior="2x">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="-34" Duration="0:0:0.75" BeginTime="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.75" BeginTime="0:0:0.15" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="9" Duration="0:0:0.75" BeginTime="0:0:0.15" />
        </Storyboard>

        <Storyboard x:Key="SbStatusFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35" />
        </Storyboard>

        <Storyboard x:Key="SbPixelDrift" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="0" To="20" Duration="0:0:12" />
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="20" Duration="0:0:12" />
        </Storyboard>

        <!-- Crest crystal geometry (reused) -->
        <Geometry x:Key="CrestHexGeometry">M50,4 94,27 94,73 50,96 6,73 6,27 Z</Geometry>
        <Geometry x:Key="CrestHeartGeometry">M50,48 C44,40 34,42 34,52 C34,62 50,76 50,76 C50,76 66,62 66,52 C66,42 56,40 50,48 Z</Geometry>

        <Style x:Key="SurvivePanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurvivePanel}" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style x:Key="SurviveButton" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="{StaticResource SurviveWhite}" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe UI Semibold, Segoe UI" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF6B9D" BlurRadius="0" ShadowDepth="0" Opacity="0" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#252525" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SurvivePink}" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.05" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.05" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0.7" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                                             To="10" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                             To="0" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SurviveCrestButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SurviveWhite}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI Black, Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransformOrigin="0.5,0.5" MinHeight="58">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Grid.RenderTransform>
                            <Path x:Name="HexGlow"
                                  Data="{StaticResource CrestHexGeometry}"
                                  Stretch="Uniform"
                                  Margin="4"
                                  Fill="#33FF6B9D"
                                  Stroke="{StaticResource SurvivePink}"
                                  StrokeThickness="2"
                                  Opacity="0.85">
                                <Path.Effect>
                                    <DropShadowEffect x:Name="CrestGlow" Color="#FF6B9D" BlurRadius="16" ShadowDepth="0" Opacity="0.6" />
                                </Path.Effect>
                            </Path>
                            <Path Data="{StaticResource CrestHeartGeometry}"
                                  Stretch="Uniform"
                                  Margin="22,14,22,18"
                                  Fill="#AAFFFFFF"
                                  Stroke="White"
                                  StrokeThickness="0.5"
                                  IsHitTestVisible="False" />
                            <Viewbox Stretch="Uniform" MaxHeight="22" Margin="8,0,8,8"
                                     VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                     StretchDirection="DownOnly">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Viewbox>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                            <DoubleAnimation Storyboard.TargetName="CrestGlow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.5" To="1" Duration="0:0:0.45" />
                                            <DoubleAnimation Storyboard.TargetName="CrestGlow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="24" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.04" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.04" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HexGlow" Property="Opacity" Value="1" />
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.92" ScaleY="0.92" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SurviveStatBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#0A0A0A" />
            <Setter Property="Foreground" Value="{StaticResource SurviveHp}" />
        </Style>

        <Style x:Key="SurviveCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SurviveMuted}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <!-- Pet creature fill brushes per state -->
        <LinearGradientBrush x:Key="PetFillHealthy" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0FAFF" Offset="0" />
            <GradientStop Color="#4DF0FF" Offset="0.45" />
            <GradientStop Color="#00B8D4" Offset="0.85" />
            <GradientStop Color="#0097A7" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PetFillTired" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#6B5A45" Offset="0" />
            <GradientStop Color="#8B7355" Offset="0.5" />
            <GradientStop Color="#A09078" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PetFillSick" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#330A0A" Offset="0" />
            <GradientStop Color="#661A2E" Offset="0.5" />
            <GradientStop Color="#992244" Offset="1" />
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Margin="4">
        <!-- Outer cyan/white glow -->
        <Border Margin="4"
                CornerRadius="24,18,26,20"
                IsHitTestVisible="False"
                Opacity="0.85">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="28" ShadowDepth="0" Opacity="0.55" />
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF3864" BlurRadius="22" ShadowDepth="0" Opacity="0.45" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <Border x:Name="RootShell"
                Background="{StaticResource DigiShellBg}"
                BorderBrush="{StaticResource DigiShellBorder}"
                BorderThickness="1.5"
                Padding="10,10,8,14"
                ClipToBounds="True"
                SizeChanged="OnRootShellSizeChanged">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                            <Setter Property="Background" Value="{StaticResource SurviveBg}" />
                            <Setter Property="BorderBrush" Value="#55FFFFFF" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#12100E" Offset="0" />
                                        <GradientStop Color="#1A1612" Offset="1" />
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Digital grid floor -->
            <Canvas Grid.RowSpan="7" IsHitTestVisible="False" VerticalAlignment="Bottom" Height="120" Opacity="0.28">
                <Canvas.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource SbGridPulse}" />
                    </EventTrigger>
                </Canvas.Triggers>
                <Rectangle Canvas.Left="0" Canvas.Top="80" Width="400" Height="1" Fill="{StaticResource DigiCyan}" Opacity="0.5" />
                <Rectangle Canvas.Left="0" Canvas.Top="95" Width="400" Height="1" Fill="{StaticResource DigiCyan}" Opacity="0.35" />
                <Rectangle Canvas.Left="0" Canvas.Top="110" Width="400" Height="1" Fill="{StaticResource DigiCyan}" Opacity="0.2" />
                <Line X1="20" Y1="80" X2="120" Y2="110" Stroke="{StaticResource DigiGrid}" StrokeThickness="1" />
                <Line X1="80" Y1="80" X2="180" Y2="110" Stroke="{StaticResource DigiGrid}" StrokeThickness="1" />
                <Line X1="140" Y1="80" X2="240" Y2="110" Stroke="{StaticResource DigiGrid}" StrokeThickness="1" />
                <Line X1="200" Y1="80" X2="300" Y2="110" Stroke="{StaticResource DigiGrid}" StrokeThickness="1" />
            </Canvas>

            <!-- Floating data shards -->
            <Canvas Grid.RowSpan="7" IsHitTestVisible="False" Opacity="0.7">
                <Path Data="M24,40 L34,58 L14,58 Z" Fill="{StaticResource DigiPartnerOrange}" Opacity="0.55"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform><TranslateTransform /></Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard Storyboard="{StaticResource SbShardFloat}" />
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
                <Path Data="M248,72 L262,96 L234,96 Z" Fill="{StaticResource DigiPartnerBlue}" Opacity="0.5"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform><TranslateTransform Y="4" /></Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="4" To="-6" Duration="0:0:2.8" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
                <Path Data="M210,28 L222,48 L198,48 Z" Fill="{StaticResource DigiPartnerYellow}" Opacity="0.45"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform><TranslateTransform /></Path.RenderTransform>
                    <Path.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                     From="0" To="-8" Duration="0:0:3.1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Path.Triggers>
                </Path>
            </Canvas>

            <!-- Wing silhouettes (hero, healthy) -->
            <Canvas Grid.RowSpan="7" IsHitTestVisible="False" Height="200" VerticalAlignment="Top" Margin="0,30,0,0">
                <Path Data="M30,60 Q8,20 40,8 Q70,28 58,72 Z"
                      Fill="#2200E5FF" Stroke="#6600E5FF" StrokeThickness="1" Opacity="0"
                      RenderTransformOrigin="0.3,0.6">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                    <Setter Property="Opacity" Value="0.5" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource SbWingGlow}" />
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Path Data="M250,55 Q278,12 240,6 Q210,30 222,68 Z"
                      Fill="#22FFFFFF" Stroke="#8800E5FF" StrokeThickness="1" Opacity="0"
                      RenderTransformOrigin="0.7,0.6">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                    <Setter Property="Opacity" Value="0.45" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Storyboard="{StaticResource SbWingGlow}" />
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
            </Canvas>

            <!-- Animated diagonal pixel / diamond pattern -->
            <Border Grid.RowSpan="7" IsHitTestVisible="False" Opacity="0.22" ClipToBounds="True">
                <Border.RenderTransform>
                    <TranslateTransform />
                </Border.RenderTransform>
                <Border.Background>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute"
                                  Viewbox="0,0,20,20" ViewboxUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="#18FFFFFF">
                                    <GeometryDrawing.Geometry>
                                        <PathGeometry Figures="M0,10 L10,0 L20,10 L10,20 Z" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing Brush="#0CFFFFFF">
                                    <GeometryDrawing.Geometry>
                                        <PathGeometry Figures="M0,10 L10,20 L0,20 Z M10,0 L20,10 L20,0 Z" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Border.Background>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard Storyboard="{StaticResource SbPixelDrift}" />
                    </EventTrigger>
                </Border.Triggers>
            </Border>

            <!-- Vignette -->
            <Border Grid.RowSpan="7" IsHitTestVisible="False">
                <Border.Background>
                    <RadialGradientBrush Center="0.35,0.25" GradientOrigin="0.35,0.25" RadiusX="0.9" RadiusY="0.85">
                        <GradientStop Color="#00000000" Offset="0" />
                        <GradientStop Color="#CC0A0A0A" Offset="1" />
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- Header / drag region -->
            <Grid Grid.Row="0" Margin="0,0,52,10"
                  MouseLeftButtonDown="OnDragRegionMouseLeftButtonDown"
                  Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="22" Height="26" Margin="0,0,8,0">
                        <Path Data="{StaticResource CrestHexGeometry}">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Fill" Value="#4400E5FF" />
                                    <Setter Property="Stroke" Value="{StaticResource DigiCyan}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                            <Setter Property="Fill" Value="#44FF6B9D" />
                                            <Setter Property="Stroke" Value="{StaticResource SurvivePink}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                            <Path.Effect>
                                <DropShadowEffect Color="#00E5FF" BlurRadius="10" ShadowDepth="0" Opacity="0.85" />
                            </Path.Effect>
                        </Path>
                    </Viewbox>
                    <TextBlock Text="DIGI-PET"
                               FontFamily="Segoe UI Black, Segoe UI"
                               FontWeight="Black"
                               FontSize="17"
                               Foreground="{StaticResource DigiWhite}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <SkewTransform AngleX="-6" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="1" Direction="315" Opacity="0.9" />
                        </TextBlock.Effect>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SurviveWhite}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <!-- Pet Arena — character left, crest right -->
            <Border Grid.Row="1" Style="{StaticResource SurvivePanelBorder}" Margin="0,0,0,8"
                    Visibility="{Binding ShowRamStats, Converter={StaticResource BoolToVis}}">
                <Grid MinHeight="155">
                    <Border x:Name="HealFlashOverlay"
                            Background="#FF6B9D"
                            Opacity="0"
                            IsHitTestVisible="False" />

                    <Ellipse x:Name="PetGlowRing"
                             Width="100" Height="100"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center"
                             Margin="20,0,0,0"
                             Fill="#3300E5FF"
                             Opacity="0.45"
                             IsHitTestVisible="False"
                             RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHealing}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Storyboard="{StaticResource SbHealGlow}" />
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0.25" To="0.55" Duration="0:0:1.6" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <Canvas x:Name="ParticleCanvas" IsHitTestVisible="False" Height="140">
                        <TextBlock x:Name="Particle1" Text="◆" FontSize="10" Foreground="{StaticResource DigiCyanSoft}"
                                   Canvas.Left="50" Canvas.Top="55" Opacity="0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><TranslateTransform /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="Particle2" Text="◇" FontSize="12" Foreground="{StaticResource SurviveWhite}"
                                   Canvas.Left="110" Canvas.Top="48" Opacity="0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><TranslateTransform /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock x:Name="Particle3" Text="◆" FontSize="9" Foreground="{StaticResource DigiPartnerOrange}"
                                   Canvas.Left="80" Canvas.Top="60" Opacity="0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform><TranslateTransform /></TextBlock.RenderTransform>
                        </TextBlock>
                    </Canvas>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Pet creature (vector silhouette) -->
                        <StackPanel x:Name="PetArena" Grid.Column="0"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="4,0,0,0"
                                    RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1" />
                                    <TranslateTransform X="0" Y="0" />
                                </TransformGroup>
                            </StackPanel.RenderTransform>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="HealthyBounceSb" Storyboard="{StaticResource SbHealthyBounce}" />
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="HealthyBounceSb" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="TiredBreatheSb" Storyboard="{StaticResource SbTiredBreathe}" />
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="TiredBreatheSb" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="SickShakeSb" Storyboard="{StaticResource SbSickShake}" />
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="SickShakeSb" />
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsHealing}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Storyboard="{StaticResource SbHealPulse}" />
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource SbIdlePulse}" />
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid Width="120" Height="105">
                                <!-- Sweat (sick) -->
                                <Path Data="M18,18 L22,28 L14,28 Z" Fill="#88AADDFF" Opacity="0"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform><TranslateTransform /></Path.RenderTransform>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                    <Setter Property="Opacity" Value="0.8" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource SbSweatDrop}" />
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M98,22 L102,32 L94,32 Z" Fill="#66AADDFF" Opacity="0"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform><TranslateTransform /></Path.RenderTransform>
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                    <Setter Property="Opacity" Value="0.65" />
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                                 From="0" To="12" Duration="0:0:1.2" />
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>

                                <Viewbox Width="110" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="200" Height="180">
                                        <Ellipse Canvas.Left="42" Canvas.Top="158" Width="116" Height="16"
                                                 Fill="#33FF3864" />

                                        <!-- Tail -->
                                        <Path Data="M52,98 Q18,88 14,62 Q10,42 32,38 L42,58 Q36,78 54,90 Z"
                                              Stroke="#AAFFFFFF" StrokeThickness="1.5">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Fill" Value="{StaticResource PetFillHealthy}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PetFillTired}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PetFillSick}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>

                                        <!-- Body -->
                                        <Path Data="M58,88 Q38,68 44,48 Q52,22 88,18 Q128,14 148,36 Q172,58 160,90 Q148,128 98,132 Q62,134 58,88 Z"
                                              Stroke="White" StrokeThickness="2">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Fill" Value="{StaticResource PetFillHealthy}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PetFillTired}" />
                                                            <Setter Property="Opacity" Value="0.75" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="{StaticResource PetFillSick}" />
                                                            <Setter Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <SkewTransform AngleX="4" CenterX="100" CenterY="90" />
                                                                </Setter.Value>
                                                            </Setter>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                        <ColorAnimation Storyboard.TargetProperty="(Path.Fill).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)"
                                                                                        To="#80FFFF" Duration="0:0:1.2" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                            <Path.Effect>
                                                <DropShadowEffect Color="#00E5FF" BlurRadius="16" ShadowDepth="0" Opacity="0.45" />
                                            </Path.Effect>
                                        </Path>

                                        <!-- Horns -->
                                        <Path Data="M78,20 L70,2 L86,16 Z" Stroke="White" StrokeThickness="1">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Fill" Value="#FF6B9D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="#8B7355" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="#661A2E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="M100,16 L108,-2 L104,18 Z" Stroke="White" StrokeThickness="1">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Fill" Value="#FF6B9D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="#8B7355" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="#661A2E" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>

                                        <!-- Eye -->
                                        <Ellipse Canvas.Left="122" Canvas.Top="44" Width="14" Height="16" Fill="White" />
                                        <Ellipse Canvas.Left="125" Canvas.Top="48" Width="7" Height="9" Fill="#0A0A0A" />

                                        <!-- Arm -->
                                        <Path Data="M54,78 L30,90 L36,102 L56,92 Z" Stroke="#88FFFFFF" StrokeThickness="1">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Fill" Value="#E5335A" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="#6B5A45" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="#441122" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>

                                        <!-- Legs -->
                                        <Path Data="M78,122 L70,152 L92,152 L96,122 Z" Fill="#CC2244" Stroke="#88FFFFFF" StrokeThickness="1">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="#5A4A38" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="#331018" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Path Data="M108,122 L102,154 L124,154 L120,122 Z" Fill="#CC2244" Stroke="#88FFFFFF" StrokeThickness="1">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPetTired}" Value="True">
                                                            <Setter Property="Fill" Value="#5A4A38" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                            <Setter Property="Fill" Value="#331018" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                    </Canvas>
                                </Viewbox>

                                <!-- Healing energy crystal -->
                                <Viewbox Width="28" Height="32" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,4,8" Opacity="0"
                                         RenderTransformOrigin="0.5,0.5">
                                    <Viewbox.RenderTransform><TranslateTransform Y="20" /></Viewbox.RenderTransform>
                                    <Path Data="{StaticResource CrestHexGeometry}"
                                          Fill="#AAFF6B9D" Stroke="White" StrokeThickness="2" />
                                    <Viewbox.Style>
                                        <Style TargetType="Viewbox">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsHealing}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource SbEatEnergy}" />
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Viewbox.Style>
                                </Viewbox>
                            </Grid>

                            <TextBlock Text="{Binding PetSpeciesName}"
                                       FontFamily="Segoe UI Black, Segoe UI"
                                       FontWeight="Black"
                                       FontSize="13"
                                       Foreground="{StaticResource DigiCyanSoft}"
                                       HorizontalAlignment="Left"
                                       Margin="8,0,0,0"
                                       RenderTransformOrigin="0,0.5">
                                <TextBlock.RenderTransform>
                                    <SkewTransform AngleX="-4" />
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                            <ColorAnimation Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                                            To="#FF3864" Duration="0:0:0.6" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource DigiWhite}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding PetMoodText}"
                                       FontSize="9" Foreground="{StaticResource SurviveMuted}"
                                       HorizontalAlignment="Left" TextWrapping="Wrap"
                                       Margin="8,2,0,0" MaxWidth="140">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPetHealthy}" Value="True">
                                                <Setter Property="Foreground" Value="#CCCCCC" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SurviveAccent}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="8,6,0,0">
                                <StackPanel Margin="0,0,14,0"
                                            Visibility="{Binding ShowCpuStats, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="CPU" FontSize="8" Foreground="{StaticResource SurviveMuted}" />
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource SurviveMp}">
                                        <Run Text="{Binding CpuPercent, StringFormat={}{0:F0}, Mode=OneWay}" />
                                        <Run Text="%" FontSize="8" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Visibility="{Binding ShowDiskStats, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="DISK" FontSize="8" Foreground="{StaticResource SurviveMuted}" />
                                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource SurviveSp}">
                                        <Run Text="{Binding DiskPercent, StringFormat={}{0:F0}, Mode=OneWay}" />
                                        <Run Text="%" FontSize="8" />
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Crest emblem (right) -->
                        <Viewbox Grid.Column="1" Width="52" Height="64"
                                 VerticalAlignment="Top" Margin="0,8,2,0"
                                 RenderTransformOrigin="0.5,0.5">
                            <Viewbox.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Viewbox.RenderTransform>
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHealing}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="3x" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1.2" Duration="0:0:0.3" />
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         To="1.2" Duration="0:0:0.3" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard Storyboard="{StaticResource SbCrestIdlePulse}" />
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Canvas Width="100" Height="100">
                                <Path Data="{StaticResource CrestHexGeometry}"
                                      Fill="#33FF6B9D"
                                      Stroke="{StaticResource SurvivePink}"
                                      StrokeThickness="3">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#FF6B9D" BlurRadius="18" ShadowDepth="0" Opacity="0.85" />
                                    </Path.Effect>
                                </Path>
                                <Path Data="M50,22 L62,38 L50,72 L38,38 Z"
                                      Fill="#55FFFFFF" Stroke="White" StrokeThickness="1" />
                                <Path Data="{StaticResource CrestHeartGeometry}"
                                      Fill="#EEFFFFFF" Stroke="#FF6B9D" StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <Border IsHitTestVisible="False" BorderThickness="1" BorderBrush="#44FFFFFF" Opacity="0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPetSick}" Value="True">
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SurviveAccent}" />
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Storyboard="{StaticResource SbSickPulse}" />
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Grid>
            </Border>

            <!-- Memory RPG Bars -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,6">
                <StackPanel Visibility="{Binding ShowRamStats, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="HP · Physischer Speicher" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource SurviveHp}" Margin="0,0,0,2" />
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="HpBar"
                                     Style="{StaticResource SurviveStatBar}"
                                     HorizontalAlignment="Stretch"
                                     Maximum="100"
                                     Value="{Binding PhysicalUsedPercent, Mode=OneWay}"
                                     Foreground="{StaticResource SurviveHp}" />
                        <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="9"
                                   VerticalAlignment="Center" Foreground="{StaticResource SurviveMuted}"
                                   Text="{Binding RamPercentDisplay, Mode=OneWay}" />
                    </Grid>
                    <TextBlock Text="{Binding RamDisplay, Mode=OneWay}" FontSize="8"
                               Foreground="{StaticResource SurviveMuted}" Margin="0,0,0,8" />

                    <TextBlock Text="MP · Ausgelagerte Dateien" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource SurviveMp}" Margin="0,0,0,2" />
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="MpBar"
                                     Style="{StaticResource SurviveStatBar}"
                                     HorizontalAlignment="Stretch"
                                     Maximum="100"
                                     Value="{Binding PageFileUsedPercent, Mode=OneWay}"
                                     Foreground="{StaticResource SurviveMp}" />
                        <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="9"
                                   VerticalAlignment="Center" Foreground="{StaticResource SurviveMuted}">
                            <Run Text="{Binding PageFileUsedPercent, StringFormat={}{0:F0}, Mode=OneWay}" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="{Binding PageFileDisplay, Mode=OneWay}" FontSize="8"
                               Foreground="{StaticResource SurviveMuted}" Margin="0,0,0,8" />

                    <TextBlock Text="SP · Systemreserviert" FontSize="9" FontWeight="Bold"
                               Foreground="{StaticResource SurviveSp}" Margin="0,0,0,2" />
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="SpBar"
                                     Style="{StaticResource SurviveStatBar}"
                                     HorizontalAlignment="Stretch"
                                     Maximum="100"
                                     Value="{Binding SystemReservedUsedPercent, Mode=OneWay}"
                                     Foreground="{StaticResource SurviveSp}" />
                        <TextBlock Grid.Column="1" Margin="6,0,0,0" FontSize="9"
                                   VerticalAlignment="Center" Foreground="{StaticResource SurviveMuted}">
                            <Run Text="{Binding SystemReservedUsedPercent, StringFormat={}{0:F0}, Mode=OneWay}" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="{Binding SystemReservedDisplay, Mode=OneWay}" FontSize="8"
                               Foreground="{StaticResource SurviveMuted}" Margin="0,0,0,4" />
                </StackPanel>
            </ScrollViewer>

            <!-- Purge Options -->
            <Border Grid.Row="3" Style="{StaticResource SurvivePanelBorder}" Margin="0,0,0,6"
                    Visibility="{Binding ShowMemoryCleanAction, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <Button Command="{Binding TogglePurgeOptionsCommand}"
                            Style="{StaticResource SurviveButton}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Margin="0,0,0,4">
                        <TextBlock TextTrimming="None" TextWrapping="NoWrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="▸ Bereiche wählen" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowPurgeOptions}" Value="True">
                                            <Setter Property="Text" Value="▾ Bereiche wählen" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <StackPanel Visibility="{Binding ShowPurgeOptions, Converter={StaticResource BoolToVis}}">
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Working set"
                                  IsChecked="{Binding PurgeWorkingSet}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="System file cache"
                                  IsChecked="{Binding PurgeSystemFileCache}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Modified page list"
                                  IsChecked="{Binding PurgeModifiedPageList}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Standby list"
                                  IsChecked="{Binding PurgeStandbyList}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Standby ohne Priorität"
                                  IsChecked="{Binding PurgeLowPriorityStandby}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Registry cache"
                                  IsChecked="{Binding PurgeRegistryCache}" />
                        <CheckBox Style="{StaticResource SurviveCheckBox}" Content="Combine memory lists (Win10+)"
                                  IsChecked="{Binding PurgeCombineMemoryLists}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <UniformGrid Grid.Row="4" Columns="3" Margin="0,0,0,6" HorizontalAlignment="Stretch">
                <Button Content="Cursor Dev"
                        Command="{Binding ApplyCursorDevModeCommand}"
                        Style="{StaticResource SurviveButton}"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding ShowCursorDevModeAction, Converter={StaticResource BoolToVis}}" />
                <Button Content="Disk"
                        Command="{Binding OptimizeDiskCommand}"
                        Style="{StaticResource SurviveButton}"
                        Margin="0,0,4,0"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding ShowDiskOptimizeAction, Converter={StaticResource BoolToVis}}" />
                <Button Content="FX Perf"
                        Command="{Binding ApplyVisualPerformanceCommand}"
                        Style="{StaticResource SurviveButton}"
                        HorizontalAlignment="Stretch"
                        Visibility="{Binding ShowVisualEffectsAction, Converter={StaticResource BoolToVis}}" />
            </UniformGrid>

            <!-- Status -->
            <TextBlock x:Name="StatusBlock"
                       Grid.Row="5"
                       Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       FontSize="9"
                       Margin="0,0,0,6"
                       MinHeight="14"
                       Opacity="1">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource SurviveMuted}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="True">
                                <Setter Property="Foreground" Value="#FF6B9D" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsStatusSuccess}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource SurviveAccent}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Crest / Heal button -->
            <Button Grid.Row="6"
                    Margin="0,0,0,4"
                    Content="SPEICHER REINIGEN"
                    Command="{Binding CleanMemoryCommand}"
                    Style="{StaticResource SurviveCrestButton}"
                    Visibility="{Binding ShowMemoryCleanAction, Converter={StaticResource BoolToVis}}" />
        </Grid>
        </Border>

        <!-- Header controls above organic clip -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,12,0"
                    Panel.ZIndex="300">
            <Button ToolTip="Hauptfenster öffnen"
                    Command="{Binding OpenMainWindowCommand}"
                    Style="{StaticResource SurviveButton}"
                    Width="28" Height="28" Padding="0" Margin="0,0,6,0"
                    Content="⧉" FontSize="12" />
            <Button x:Name="KillButton"
                    Content="✕"
                    Style="{StaticResource KillButtonStyle}"
                    Click="OnKillButtonClick"
                    IsEnabled="True" />
        </StackPanel>
    </Grid>
</Window>
