{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "AppSettings": {
    "DefenderOptIn": false,
    "SnapshotRetentionLimit": 50,
    "MetricsPollingIntervalMs": 2000,
    "DefaultDevFolders": [ "node_modules", ".git", "dist", "build" ]
  },
  "Velopack": {
    "UpdateFeedUrl": "https://github.com/HorosCloudOfficial/HorosPulse",
    "CheckOnStartup": true
  }
}
