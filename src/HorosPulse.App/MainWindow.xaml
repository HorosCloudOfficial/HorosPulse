<Window x:Class="HorosPulse.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        mc:Ignorable="d"
        Title="HorosPulse"
        Height="720"
        Width="1100"
        MinHeight="500"
        MinWidth="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
    <tb:TaskbarIcon x:Name="TrayIcon"
                    ToolTipText="HorosPulse"
                    Visibility="Collapsed"
                    TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
        <tb:TaskbarIcon.IconSource>
            <tb:GeneratedIconSource Text="&#xE9D9;"
                                    FontFamily="Segoe MDL2 Assets"
                                    Foreground="#7AA2F7"
                                    Background="#1E1E2E"
                                    FontSize="12" />
        </tb:TaskbarIcon.IconSource>
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu Style="{StaticResource TrayContextMenuStyle}"
                         Background="#24283B"
                         Foreground="#C0CAF5"
                         BorderBrush="#3B4261">
                <MenuItem Header="Fenster öffnen"
                          Click="TrayOpen_Click"
                          Style="{StaticResource TrayMenuItemStyle}" />
                <MenuItem Header="Kompakt-Fenster öffnen"
                          Click="TrayOpenCompact_Click"
                          Style="{StaticResource TrayMenuItemStyle}" />
                <Separator Style="{StaticResource TrayMenuSeparatorStyle}" />
                <MenuItem Header="Beenden"
                          Click="TrayExit_Click"
                          Style="{StaticResource TrayMenuItemStyle}" />
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

    <Border Background="{StaticResource PrimaryDarkBrush}"
            BorderBrush="{StaticResource TertiaryDarkBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2"
                  Background="{StaticResource SecondaryDarkBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBlueBrush}"
                               FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="HorosPulse" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Grid.Column="1" Text="Cursor IDE Workflow Optimizer"
                           VerticalAlignment="Center" Margin="8,0"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="12" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="&#xE921;"
                            Click="MinimizeButton_Click" ToolTip="Minimieren" />
                    <Button Style="{StaticResource TitleBarButtonStyle}" Content="&#xE922;"
                            Click="MaximizeButton_Click" ToolTip="Maximieren" />
                    <Button Style="{StaticResource TitleBarCloseButtonStyle}" Content="&#xE8BB;"
                            Click="CloseButton_Click" ToolTip="Schließen" />
                </StackPanel>
            </Grid>

            <!-- Sidebar -->
            <Border Grid.Row="1" Grid.Column="0"
                    Background="{StaticResource SecondaryDarkBrush}"
                    BorderBrush="{StaticResource TertiaryDarkBrush}"
                    BorderThickness="0,1,1,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding AppVersion, StringFormat='v{0}'}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               Margin="16,12"
                               HorizontalAlignment="Left" />

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,12,0,0">
                        <StackPanel>
                        <Button Content="Dashboard" Command="{Binding NavigateToDashboardCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Dashboard">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Energie" Command="{Binding NavigateToEnergieCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Energie">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Cursor" Command="{Binding NavigateToCursorCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Cursor">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Monitor" Command="{Binding NavigateToMonitorCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Monitor">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Snapshots" Command="{Binding NavigateToSnapshotsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Snapshots">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Presets" Command="{Binding NavigateToPresetsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Presets">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Dienste" Command="{Binding NavigateToServicesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Dienste">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Startup" Command="{Binding NavigateToStartupCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Startup">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Visuell" Command="{Binding NavigateToVisualEffectsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Visuell">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Speicher" Command="{Binding NavigateToMemoryCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Speicher">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Netzwerk" Command="{Binding NavigateToNetworkCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Netzwerk">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Build-Schutz" Command="{Binding NavigateToBuildToolDefenderCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Build-Schutz">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Trends" Command="{Binding NavigateToTrendsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Trends">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Prozesse" Command="{Binding NavigateToProcessInspectorCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Prozesse">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Festplatte" Command="{Binding NavigateToDiskCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Festplatte">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Tasks" Command="{Binding NavigateToTaskSchedulerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Tasks">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Registry" Command="{Binding NavigateToRegistryTunerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Registry">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Einstellungen" Command="{Binding NavigateToEinstellungenCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SidebarNavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedNavItem}" Value="Einstellungen">
                                            <Setter Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content -->
            <ContentControl x:Name="MainContent"
                            Grid.Row="1" Grid.Column="1"
                            Content="{Binding CurrentViewModel}"
                            Margin="24">
                <ContentControl.RenderTransform>
                    <TranslateTransform x:Name="ContentTranslate" X="0" />
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>
    </Border>
    </Grid>
</Window>
