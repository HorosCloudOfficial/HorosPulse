<UserControl x:Class="HorosPulse.App.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding WarningText}" Foreground="{StaticResource AccentOrangeBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,16" />
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="RAM vorher (verfügbar)" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock FontSize="28" FontWeight="Bold">
                                <Run Text="{Binding RamBeforeMb}" />
                                <Run Text=" MB" FontSize="14" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="RAM nachher (verfügbar)" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}">
                                <Run Text="{Binding RamAfterMb}" />
                                <Run Text=" MB" FontSize="14" />
                            </TextBlock>
                        </StackPanel>
                    </UniformGrid>
                    <Button Content="Standby-Speicher leeren (Flush)" Command="{Binding FlushCommand}" HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
