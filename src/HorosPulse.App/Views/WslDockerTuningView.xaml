<UserControl x:Class="HorosPulse.App.Views.WslDockerTuningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="WSL2-Ressourcen-Limits (.wslconfig) und Docker-Status für Dev-Setups — dokumentierte Microsoft-Einstellungen mit Backup und Rollback."
                               Foreground="{StaticResource TextMutedBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding RecommendationSummary}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Empfehlung anwenden" Command="{Binding ApplyCommand}" Margin="0,0,8,0" />
                        <Button Content="Rollback" Command="{Binding RollbackCommand}" Margin="0,0,8,0"
                                IsEnabled="{Binding HasHorosPulseChanges}" />
                        <Button Content="wsl --shutdown" Command="{Binding ShutdownWslCommand}" Margin="0,0,8,0" />
                        <Button Content="Aktualisieren" Command="{Binding RefreshCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Erkennung" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="WSL" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding WslStatusSummary}" TextWrapping="Wrap" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Docker" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding DockerStatusSummary}" TextWrapping="Wrap" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text=".wslconfig" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding WslConfigPath}" TextWrapping="Wrap" FontSize="11" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Ressourcen-Vergleich" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="Aktuell (WSL)" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="System" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="Empfehlung" FontWeight="SemiBold" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Arbeitsspeicher" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentMemoryDisplay}" />
                        <TextBlock Grid.Column="2" Text="{Binding SystemMemoryDisplay}" />
                        <TextBlock Grid.Column="3" Text="{Binding RecommendedMemoryDisplay}"
                                   Foreground="{StaticResource AccentBlueBrush}" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Prozessoren" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentProcessorsDisplay}" />
                        <TextBlock Grid.Column="2" Text="{Binding SystemProcessorsDisplay}" />
                        <TextBlock Grid.Column="3" Text="{Binding RecommendedProcessorsDisplay}"
                                   Foreground="{StaticResource AccentBlueBrush}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Swap" Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Grid.Column="1" Text="{Binding CurrentSwapDisplay}" />
                        <TextBlock Grid.Column="2" Text="—" />
                        <TextBlock Grid.Column="3" Text="{Binding RecommendedSwapDisplay}"
                                   Foreground="{StaticResource AccentBlueBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Build-Schutz" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding BuildDefenderHint}" TextWrapping="Wrap"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                    <TextBlock Text="Defender-Prozess-Ausschlüsse für docker.exe und wsl.exe werden im Modul „Build-Schutz“ verwaltet — nicht hier dupliziert."
                               TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12" />
                    <Button Content="Build-Schutz öffnen" Command="{Binding OpenBuildDefenderCommand}"
                            HorizontalAlignment="Left"
                            Visibility="{Binding ShowBuildDefenderLink, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Empfehlungen" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource TertiaryDarkBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,0,0,12"
                                        Margin="0,0,0,12">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                                                       Foreground="{StaticResource AccentBlueBrush}" />
                                        </Grid>
                                        <TextBlock Text="{Binding Description}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap" Margin="0,0,0,4" />
                                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                            <Run Text="Aktuell: " />
                                            <Run Text="{Binding CurrentDisplay, Mode=OneWay}" />
                                            <Run Text=" · Empfohlen: " />
                                            <Run Text="{Binding RecommendedDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
