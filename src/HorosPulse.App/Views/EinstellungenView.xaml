<UserControl x:Class="HorosPulse.App.Views.EinstellungenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{Binding Title, Mode=OneWay}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

            <TabControl SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Header="Allgemein">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <CheckBox Content="Windows Defender Ausnahmen erlauben (Opt-in)"
                                      IsChecked="{Binding DefenderOptIn}"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Standard Dev-Ordner (Indexer)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding DefaultDevFoldersText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Snapshot-Aufbewahrung (max. Anzahl)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding SnapshotRetentionLimit, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Theme" Margin="0,0,0,4" />
                            <ComboBox Style="{StaticResource TokyoNightComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource TokyoNightComboBoxItemStyle}"
                                      ItemsSource="{Binding AvailableThemes}"
                                      SelectedItem="{Binding SelectedTheme}"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="Log-Level (Serilog)" Margin="0,0,0,4" />
                            <ComboBox Style="{StaticResource TokyoNightComboBoxStyle}"
                                      ItemContainerStyle="{StaticResource TokyoNightComboBoxItemStyle}"
                                      ItemsSource="{Binding AvailableLogLevels}"
                                      SelectedItem="{Binding SelectedLogLevel}"
                                      Margin="0,0,0,12" />

                            <CheckBox Content="Mit Windows starten"
                                      IsChecked="{Binding AutoStartWithWindows}"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="PowerShell-Timeout (Sekunden)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding PowerShellTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Monitor: Refresh-Intervall (ms)" Margin="0,0,0,4" />
                            <TextBox Text="{Binding ProcessMonitorRefreshIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <CheckBox Content="Monitor: nur Cursor-relevante Prozesse"
                                      IsChecked="{Binding ProcessMonitorCursorFilterOnly}"
                                      Margin="0,0,0,12" />

                            <CheckBox Content="Windows-Suchdienst nach Indexer-Änderung neu starten (Opt-in)"
                                      IsChecked="{Binding RestartSearchServiceAfterIndexerChange}"
                                      Margin="0,0,0,12" />

                            <CheckBox Content="Cursor-Prioritäten bei Neustart automatisch anwenden"
                                      IsChecked="{Binding ReapplyCursorPrioritiesOnRestart}"
                                      Margin="0,0,0,16" />

                            <Button Content="Einstellungen speichern"
                                    Command="{Binding SaveSettingsCommand}"
                                    HorizontalAlignment="Left" />

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Audit-Protokoll">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="Letzte Einträge" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button Content="Aktualisieren"
                                        Command="{Binding LoadAuditLogCommand}"
                                        Margin="16,0,8,0" />
                                <Button Content="CSV exportieren"
                                        Command="{Binding ExportAuditCsvCommand}" />
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding AuditEntries}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      MinHeight="240"
                                      Background="{StaticResource SecondaryDarkBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      BorderBrush="{StaticResource TertiaryDarkBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Zeit" Binding="{Binding Timestamp, StringFormat={}{0:g}}" Width="140" />
                                    <DataGridTextColumn Header="Operation" Binding="{Binding Operation}" Width="100" />
                                    <DataGridTextColumn Header="Modul" Binding="{Binding Module}" Width="120" />
                                    <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Kompakt-Fenster">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Kompakt-Fenster"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="Digi-Pet Mini-Fenster (Tamagotchi/Digimon-Stil) mit Mem-Reduct-Funktionen und Schnellaktionen."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16" />

                            <TextBlock Text="Anzeige" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox Content="RAM-Statistik anzeigen"
                                      IsChecked="{Binding CompactShowRamStats}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="CPU-Statistik anzeigen"
                                      IsChecked="{Binding CompactShowCpuStats}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Festplatten-Statistik anzeigen"
                                      IsChecked="{Binding CompactShowDiskStats}"
                                      Margin="0,0,0,16" />

                            <TextBlock Text="Schnellaktionen" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox Content="Speicher reinigen"
                                      IsChecked="{Binding CompactShowMemoryCleanAction}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Cursor Dev Mode"
                                      IsChecked="{Binding CompactShowCursorDevModeAction}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Festplatte optimieren"
                                      IsChecked="{Binding CompactShowDiskOptimizeAction}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Visuelle Effekte (Performance)"
                                      IsChecked="{Binding CompactShowVisualEffectsAction}"
                                      Margin="0,0,0,16" />

                            <TextBlock Text="Speicher-Bereiche (Standard für Kompakt-Fenster)"
                                       FontWeight="SemiBold" Margin="0,0,0,8" />
                            <CheckBox Content="Working set"
                                      IsChecked="{Binding CompactPurgeWorkingSet}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="System file cache"
                                      IsChecked="{Binding CompactPurgeSystemFileCache}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Modified page list"
                                      IsChecked="{Binding CompactPurgeModifiedPageList}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Standby list"
                                      IsChecked="{Binding CompactPurgeStandbyList}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Standby ohne Priorität"
                                      IsChecked="{Binding CompactPurgeLowPriorityStandby}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Registry cache"
                                      IsChecked="{Binding CompactPurgeRegistryCache}"
                                      Margin="0,0,0,8" />
                            <CheckBox Content="Combine memory lists (Win10+)"
                                      IsChecked="{Binding CompactPurgeCombineMemoryLists}"
                                      Margin="0,0,0,16" />

                            <CheckBox Content="Kompakt-Fenster beim Start öffnen"
                                      IsChecked="{Binding CompactOpenOnStartup}"
                                      Margin="0,0,0,16" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Kompakt-Fenster öffnen"
                                        Command="{Binding OpenCompactWindowCommand}"
                                        Margin="0,0,8,0" />
                                <Button Content="Einstellungen speichern"
                                        Command="{Binding SaveSettingsCommand}" />
                            </StackPanel>

                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{StaticResource AccentGreenBrush}" />
                        </StackPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Über">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="HorosPulse" FontSize="20" FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="Version " />
                                <TextBlock Text="{Binding AppVersion, Mode=OneWay}" FontWeight="Bold" />
                            </StackPanel>
                            <TextBlock Text="Windows-Optimierung für Cursor IDE Entwicklungsworkflows."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,12,0,16" />
                            <Button Content="Nach Updates suchen"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
