<UserControl x:Class="HorosPulse.App.Views.TaskSchedulerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Dev-Zeit-Schutz: störende Update-Tasks temporär deaktivieren (mit Rollback)." Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Dev-Schutz anwenden" Command="{Binding ApplyDevProtectionCommand}" Margin="0,0,8,0" />
                        <Button Content="Rollback" Command="{Binding RollbackCommand}" Margin="0,0,8,0" />
                        <Button Content="Aktualisieren" Command="{Binding LoadTasksCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorderStyle}">
                <DataGrid ItemsSource="{Binding Tasks}" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="280">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Pfad" Binding="{Binding Path}" Width="2*" />
                        <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsEnabled}" Width="60" />
                        <DataGridTextColumn Header="Status" Binding="{Binding State}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
