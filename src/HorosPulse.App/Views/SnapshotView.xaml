<UserControl x:Class="HorosPulse.App.Views.SnapshotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:HorosPulse.ViewModels;assembly=HorosPulse.ViewModels">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Snapshot erstellen" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="Label" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,4" />
                        <TextBox Text="{Binding NewSnapshotLabel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                        <Button Content="Snapshot jetzt erstellen"
                                Command="{Binding CreateSnapshotCommand}"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentBlueBrush}"
                                Foreground="{StaticResource PrimaryDarkBrush}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Gespeicherte Snapshots" FontWeight="SemiBold" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Rollback"
                                        Command="{Binding RollbackSelectedCommand}"
                                        Margin="0,0,8,0" />
                                <Button Content="Aktualisieren"
                                        Command="{Binding LoadSnapshotsCommand}" />
                            </StackPanel>
                        </Grid>

                        <ListBox ItemsSource="{Binding Snapshots}"
                                 SelectedItem="{Binding SelectedSnapshot}"
                                 MinHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:SnapshotItemViewModel}">
                                    <Expander>
                                        <Expander.Header>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                                    <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12">
                                                        <Run Text="{Binding CreatedAtDisplay, Mode=OneWay}" />
                                                        <Run Text=" · " />
                                                        <Run Text="{Binding Module, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" Padding="8,2" CornerRadius="10" Margin="8,0,0,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource TertiaryDarkBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentGreenBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                                    <Setter Property="Background" Value="{StaticResource AccentRedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding ValidityLabel}" FontSize="11" Foreground="{StaticResource PrimaryDarkBrush}" />
                                                </Border>
                                            </Grid>
                                        </Expander.Header>
                                        <TextBox Text="{Binding PrettyStateJson, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 MinHeight="120"
                                                 Margin="0,8,0,0"
                                                 FontFamily="Consolas"
                                                 FontSize="11" />
                                    </Expander>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource AccentOrangeBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <Border Style="{StaticResource BusyOverlayStyle}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Style="{StaticResource LoadingSpinnerStyle}" Width="40" Height="40" Margin="0,0,0,12" />
                <TextBlock Text="{Binding ProgressMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Abbrechen"
                        Command="{Binding CancelOperationCommand}"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
