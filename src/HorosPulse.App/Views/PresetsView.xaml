<UserControl x:Class="HorosPulse.App.Views.PresetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16" />

                    <ListBox ItemsSource="{Binding Presets}"
                             SelectedItem="{Binding SelectedPreset}"
                             MinHeight="160"
                             Margin="0,0,0,16">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" FontSize="12" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Preset anwenden"
                                Command="{Binding ApplyPresetCommand}"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBlueBrush}"
                                Foreground="{StaticResource PrimaryDarkBrush}" />
                        <Button Content="Preset löschen"
                                Command="{Binding DeletePresetCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Rollback letzter Snapshot"
                                Command="{Binding RollbackLatestCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Export JSON"
                                Command="{Binding ExportPresetCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Import JSON"
                                Command="{Binding ImportPresetCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Aktualisieren"
                                Command="{Binding LoadPresetsCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Benutzerdefiniertes Preset erstellen" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <TextBlock Text="Name" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewPresetName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />
                    <TextBlock Text="Beschreibung" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                    <TextBox Text="{Binding NewPresetDescription, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                    <TextBlock Text="Schritte" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding AvailableSteps}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="Preset speichern"
                            Command="{Binding SavePresetCommand}"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AccentGreenBrush}"
                            Foreground="{StaticResource PrimaryDarkBrush}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Fortschritt" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding ApplySteps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <TextBlock Width="20">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✗" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Success}" Value="True">
                                                        <Setter Property="Text" Value="✓" />
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="{Binding StepName}" FontWeight="SemiBold" />
                                        <Run Text=" — " Foreground="{StaticResource TextMutedBrush}" />
                                        <Run Text="{Binding Message}" Foreground="{StaticResource TextMutedBrush}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <Border Style="{StaticResource BusyOverlayStyle}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Style="{StaticResource LoadingSpinnerStyle}" Width="40" Height="40" Margin="0,0,0,12" />
                <TextBlock Text="{Binding ProgressMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Abbrechen"
                        Command="{Binding CancelOperationCommand}"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
