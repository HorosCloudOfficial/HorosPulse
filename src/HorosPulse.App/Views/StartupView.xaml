<UserControl x:Class="HorosPulse.App.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" MinHeight="240" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="140" />
                            <DataGridTextColumn Header="Befehl" Binding="{Binding Command}" Width="*" />
                            <DataGridTextColumn Header="Quelle" Binding="{Binding Source}" Width="80" />
                            <DataGridCheckBoxColumn Header="Aktiv" Binding="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" Width="60" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Aktualisieren" Command="{Binding LoadEntriesCommand}" Margin="0,0,8,0" />
                        <Button Content="Rollback" Command="{Binding RollbackCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
