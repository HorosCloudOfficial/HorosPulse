<UserControl x:Class="HorosPulse.App.Views.DiskOptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                <TextBlock Text="Prefetch/Superfetch, TRIM-Status und Defragmentierungs-Info (ohne Defrag-Start)." Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                <TextBlock Text="{Binding StatusText}" Margin="0,0,0,16" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Optimierungen anwenden" Command="{Binding ApplyCommand}" Margin="0,0,8,0" />
                    <Button Content="Rollback" Command="{Binding RollbackCommand}" Margin="0,0,8,0" />
                    <Button Content="Aktualisieren" Command="{Binding RefreshCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
