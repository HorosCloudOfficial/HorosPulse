<Application x:Class="HorosPulse.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:HorosPulse.App.Views"
             xmlns:vm="clr-namespace:HorosPulse.ViewModels;assembly=HorosPulse.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/TokyoNight.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EnergieViewModel}">
                <views:EnergieView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CursorViewModel}">
                <views:CursorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                <views:MonitorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SnapshotViewModel}">
                <views:SnapshotView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PresetsViewModel}">
                <views:PresetsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EinstellungenViewModel}">
                <views:EinstellungenView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ServicesViewModel}">
                <views:ServicesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:StartupViewModel}">
                <views:StartupView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VisualEffectsViewModel}">
                <views:VisualEffectsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MemoryViewModel}">
                <views:MemoryView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:NetworkViewModel}">
                <views:NetworkView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TrendViewModel}">
                <views:TrendView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ProcessInspectorViewModel}">
                <views:ProcessInspectorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:DiskOptimizerViewModel}">
                <views:DiskOptimizerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TaskSchedulerViewModel}">
                <views:TaskSchedulerView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:RegistryTunerViewModel}">
                <views:RegistryTunerView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
