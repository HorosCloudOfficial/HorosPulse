<Application x:Class="WindowsPerformance.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:WindowsPerformance.App.Views"
             xmlns:vm="clr-namespace:WindowsPerformance.ViewModels;assembly=WindowsPerformance.ViewModels">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/TokyoNight.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <views:DashboardView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EnergieViewModel}">
                <views:EnergieView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:CursorViewModel}">
                <views:CursorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MonitorViewModel}">
                <views:MonitorView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PresetsViewModel}">
                <views:PresetsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EinstellungenViewModel}">
                <views:EinstellungenView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
