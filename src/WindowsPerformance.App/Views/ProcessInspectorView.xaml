<UserControl x:Class="WindowsPerformance.App.Views.ProcessInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Width="280" Margin="0,0,8,0" />
                        <Button Content="Filtern" Command="{Binding RefreshCommand}" Margin="0,0,8,0" />
                        <Button Content="Prozess beenden" Command="{Binding KillSelectedCommand}" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Processes}"
                              SelectedItem="{Binding SelectedProcess}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              MinHeight="280">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="100" />
                            <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="60" />
                            <DataGridTextColumn Header="CPU %" Binding="{Binding CpuPercent}" Width="60" />
                            <DataGridTextColumn Header="RAM MB" Binding="{Binding WorkingSetMb}" Width="70" />
                            <DataGridTextColumn Header="Handles" Binding="{Binding HandleCount}" Width="70" />
                            <DataGridTextColumn Header="Threads" Binding="{Binding ThreadCount}" Width="70" />
                            <DataGridTextColumn Header="IO Read" Binding="{Binding IoReadBytes}" Width="80" />
                            <DataGridTextColumn Header="IO Write" Binding="{Binding IoWriteBytes}" Width="80" />
                            <DataGridTextColumn Header="Priorität" Binding="{Binding Priority}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,12,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
