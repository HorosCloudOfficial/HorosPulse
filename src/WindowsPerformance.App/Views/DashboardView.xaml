<UserControl x:Class="WindowsPerformance.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:WindowsPerformance.ViewModels;assembly=WindowsPerformance.ViewModels">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

                <UniformGrid Columns="4" Margin="0,0,0,16">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Health Score" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                            <TextBlock FontSize="36" FontWeight="Bold">
                                <Run Text="{Binding HealthScore}" Foreground="{Binding HealthScoreColor}" />
                                <Run Text="/100" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="CPU" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                            <TextBlock FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}">
                                <Run Text="{Binding CpuPercent, StringFormat={}{0:F0}}" />
                                <Run Text="%" FontSize="16" />
                            </TextBlock>
                            <lvc:CartesianChart Series="{Binding CpuSeries}"
                                                XAxes="{Binding CpuXAxes}"
                                                YAxes="{Binding CpuYAxes}"
                                                Height="56"
                                                Margin="0,8,0,0"
                                                TooltipPosition="Hidden"
                                                ZoomMode="None"
                                                AnimationsSpeed="0:0:0.15" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="RAM" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                            <TextBlock Text="{Binding RamDisplay}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" />
                            <lvc:CartesianChart Series="{Binding RamSeries}"
                                                XAxes="{Binding RamXAxes}"
                                                YAxes="{Binding RamYAxes}"
                                                Height="56"
                                                Margin="0,8,0,0"
                                                TooltipPosition="Hidden"
                                                ZoomMode="None"
                                                AnimationsSpeed="0:0:0.15" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorderStyle}" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Festplatte" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                            <TextBlock FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}">
                                <Run Text="{Binding DiskPercent, StringFormat={}{0:F0}}" />
                                <Run Text="%" FontSize="16" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Health Score Breakdown" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding HealthFactors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Text="{Binding PointsDisplay}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Modul-Status" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding ModuleStatuses}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:ModuleStatusItemViewModel}">
                                    <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,8" Padding="12" MinWidth="160">
                                        <StackPanel>
                                            <TextBlock Text="{Binding ModuleName}" FontWeight="SemiBold" />
                                            <Border Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left" Margin="0,6,0,4"
                                                    Tag="{Binding StatusTag}">
                                                <TextBlock Text="{Binding StatusLabel}" FontSize="11" Foreground="{StaticResource PrimaryDarkBrush}" />
                                            </Border>
                                            <TextBlock Text="{Binding Detail}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Systemstatus" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <TextBlock Text="{Binding HealthHint}" TextWrapping="Wrap" Foreground="{StaticResource AccentOrangeBrush}" />
                        <TextBlock Text="{Binding LastSnapshotText}" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="ML-Empfehlungen" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding Recommendations}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource TertiaryDarkBrush}" BorderThickness="0,0,0,1" Padding="0,6">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Message}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Schnellaktionen" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Cursor Dev Mode"
                                    Command="{Binding ApplyCursorDevModeCommand}"
                                    Margin="0,0,8,0"
                                    Background="{StaticResource AccentBlueBrush}"
                                    Foreground="{StaticResource PrimaryDarkBrush}" />
                            <Button Content="Rollback letzter Snapshot"
                                    Command="{Binding RollbackLatestCommand}"
                                    Margin="0,0,8,0" />
                            <Button Content="Aktualisieren"
                                    Command="{Binding RefreshCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource AccentOrangeBrush}"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Style="{StaticResource BusyOverlayStyle}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Style="{StaticResource LoadingSpinnerStyle}" Width="40" Height="40" Margin="0,0,0,12" />
                <TextBlock Text="{Binding ProgressMessage}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <Button Content="Abbrechen"
                        Command="{Binding CancelOperationCommand}"
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
