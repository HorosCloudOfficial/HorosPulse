<UserControl x:Class="WindowsPerformance.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />

            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}">
                            <Run Text="{Binding CpuPercent, StringFormat={}{0:F0}}" />
                            <Run Text="%" FontSize="16" />
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="RAM" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock Text="{Binding RamDisplay}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardBorderStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Festplatte" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                        <TextBlock FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}">
                            <Run Text="{Binding DiskPercent, StringFormat={}{0:F0}}" />
                            <Run Text="%" FontSize="16" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Systemstatus" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding HealthHint}" TextWrapping="Wrap" Foreground="{StaticResource AccentOrangeBrush}" />
                    <TextBlock Text="{Binding LastSnapshotText}" Foreground="{StaticResource TextMutedBrush}" Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Schnellaktionen" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Cursor Dev Mode"
                                Command="{Binding ApplyCursorDevModeCommand}"
                                Margin="0,0,8,0"
                                Background="{StaticResource AccentBlueBrush}"
                                Foreground="{StaticResource PrimaryDarkBrush}" />
                        <Button Content="Rollback letzter Snapshot"
                                Command="{Binding RollbackLatestCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Aktualisieren"
                                Command="{Binding RefreshCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource AccentOrangeBrush}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
