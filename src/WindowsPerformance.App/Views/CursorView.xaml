<UserControl x:Class="WindowsPerformance.App.Views.CursorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Cursor Settings -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />

                    <TextBlock Text="Vorschau der Änderungen:" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding PreviewChanges}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StringFormat=• {0}}" Foreground="{StaticResource TextMutedBrush}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Optimierungen anwenden"
                                Command="{Binding ApplySettingsCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Wiederherstellen"
                                Command="{Binding RestoreSettingsCommand}"
                                IsEnabled="{Binding HasSettingsBackup}"
                                Margin="0,0,8,0" />
                        <Button Content="Aktualisieren"
                                Command="{Binding RefreshCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Process Priority -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Prozessprioritäten" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding CursorProcessStatus}" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,12" />
                    <Button Content="Prioritäten anwenden (Cursor: Hoch, Helper: Niedrig)"
                            Command="{Binding ApplyProcessPrioritiesCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Defender -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Windows Defender Ausschlüsse" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox Content="Ich verstehe die Sicherheitsrisiken und möchte Cursor-Pfade ausschließen (Opt-in)"
                              IsChecked="{Binding DefenderOptIn}"
                              Margin="0,0,0,12" />
                    <Button Content="Defender-Ausschlüsse anwenden (Admin)"
                            Command="{Binding ApplyDefenderExclusionsCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Indexer -->
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Windows-Suche Ausschlüsse" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding IndexerEntries}" Margin="0,0,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Path}" IsChecked="{Binding IsSelected}" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Indexer-Ausschlüsse anwenden (Admin)"
                            Command="{Binding ApplyIndexerExclusionsCommand}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource AccentGreenBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
